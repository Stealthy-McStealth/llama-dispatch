# Stealthy McStealth - Llama Dispatch job-runner
CONFIG_BUCKET=
CONFIG_NAMESPACE=
REMOTE_ENV_PROFILE=job-runner-prod
REDIS_URL=redis://redis-staging.internal:6379/0
LOG_LEVEL=INFO
JOB_QUEUE_KEY=llama:jobs
AUDIT_LOG_TOPIC=audit.events
POLL_TIMEOUT_SECONDS=5
WORK_DURATION_SECONDS=0.15
HEARTBEAT_INTERVAL_SECONDS=35
SCHEDULER_TICK_INTERVAL_SECONDS=50
HEALTHCHECK_INTERVAL_SECONDS=90
